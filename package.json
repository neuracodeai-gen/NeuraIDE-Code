{
  "name": "neuraide",
  "version": "0.1.0",
  "description": "NeuraIDE - an AI-assisted Electron IDE with Monaco, terminal, explorer, preview, and configurable AI providers.",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "lint": "node --check main.js && node --check preload.js && for f in src/js/*.js; do node --input-type=module --check < \"$f\"; done",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "ide",
    "monaco",
    "ai",
    "editor"
  ],
  "author": "NeuraIDE",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "monaco-editor": "^0.49.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.neuraide.app",
    "productName": "NeuraIDE",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  }
}
